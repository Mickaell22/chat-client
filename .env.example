# URL del backend (API HTTP de auth)
# Local: http://localhost:4000 | Produccion: https://tu-backend.up.railway.app
VITE_API_URL=http://localhost:4000

# URL del servidor de WebSocket (normalmente la misma que el backend)
VITE_SOCKET_URL=http://localhost:4000

# Servidor STUN para las llamadas de voz (WebRTC). Sin el, las llamadas solo
# conectan dentro de la misma red local. Cualquier STUN publico sirve.
VITE_STUN_URL=stun:stun.l.google.com:19302
